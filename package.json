{
  "name": "ddududdudu",
  "version": "0.2.0",
  "description": "Multi-agent orchestration harness with tmux-like multi-tab TUI",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "ddudu": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && cargo build --manifest-path native/ddudu-tui/Cargo.toml --release && mkdir -p dist/native && cp native/ddudu-tui/target/release/ddudu-tui dist/native/ddudu-tui && chmod +x dist/native/ddudu-tui && node -e \"require('node:fs').chmodSync('dist/index.js', 0o755)\"",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "tui",
    "agent",
    "orchestration",
    "harness",
    "multi-agent",
    "claude",
    "codex",
    "openclaw"
  ],
  "author": "subinium",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@inkjs/ui": "^2.0.0",
    "ai": "^6.0.116",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "fullscreen-ink": "^0.1.0",
    "ink": "^6.8.0",
    "ink-markdown-es": "^1.4.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "react": "^19.2.4",
    "slice-ansi": "^8.0.0",
    "string-width": "^8.2.0",
    "strip-ansi": "^7.2.0",
    "wrap-ansi": "^10.0.0",
    "yaml": "^2.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "typescript": "^5.7.0"
  }
}
