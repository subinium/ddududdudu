{
  "name": "ddududdudu",
  "version": "0.6.4",
  "description": "AI coding harness with a native Rust TUI",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "ddudu": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "assets"
  ],
  "scripts": {
    "build": "node scripts/transpile-runner.cjs && cargo build --manifest-path tui/Cargo.toml --release && mkdir -p dist/tui && cp tui/target/release/ddudu-tui dist/tui/ddudu-tui && chmod +x dist/tui/ddudu-tui && (command -v codesign >/dev/null 2>&1 && codesign --force --deep --sign - dist/tui/ddudu-tui || true) && node -e \"require('node:fs').chmodSync('dist/index.js', 0o755)\"",
    "dev": "node --watch scripts/transpile-runner.cjs",
    "install:global": "node scripts/install-global.cjs",
    "start": "node dist/index.js",
    "typecheck": "node scripts/transpile-runner.cjs --noEmit",
    "lint:biome": "biome check src/",
    "format": "biome format --write src/",
    "format:check": "biome format src/",
    "test": "npm run build && node scripts/run-node-tests.cjs",
    "test:coverage": "npm run build && c8 node scripts/run-node-tests.cjs",
    "bench:run": "node bench/run.mjs",
    "bench:report": "node bench/report.mjs",
    "clean": "rm -rf dist",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "tui",
    "agent",
    "orchestration",
    "harness",
    "multi-agent",
    "claude",
    "codex",
    "openclaw"
  ],
  "author": "subinium",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@anthropic-ai/claude-agent-sdk": "^0.2.71",
    "@openai/codex-sdk": "^0.111.0",
    "ai": "^6.0.116",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "js-yaml": "^4.1.1",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "slice-ansi": "^8.0.0",
    "string-width": "^8.2.0",
    "strip-ansi": "^7.2.0",
    "wrap-ansi": "^10.0.0",
    "yaml": "^2.7.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "bash-language-server": "^5.6.0",
    "typescript-language-server": "^5.1.3",
    "vscode-langservers-extracted": "^4.10.0",
    "yaml-language-server": "^1.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "c8": "^11.0.0",
    "typescript": "~5.8.3"
  }
}
