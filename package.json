{
  "name": "ddududdudu",
  "version": "0.3.1",
  "description": "AI coding harness with a native Rust TUI",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "ddudu": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && cargo build --manifest-path tui/Cargo.toml --release && mkdir -p dist/tui && cp tui/target/release/ddudu-tui dist/tui/ddudu-tui && chmod +x dist/tui/ddudu-tui && (command -v codesign >/dev/null 2>&1 && codesign --force --deep --sign - dist/tui/ddudu-tui || true) && node -e \"require('node:fs').chmodSync('dist/index.js', 0o755)\"",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "npm run build && node --test test/*.test.mjs",
    "bench:run": "node bench/run.mjs",
    "bench:report": "node bench/report.mjs",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "tui",
    "agent",
    "orchestration",
    "harness",
    "multi-agent",
    "claude",
    "codex",
    "openclaw"
  ],
  "author": "subinium",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@anthropic-ai/claude-agent-sdk": "^0.2.71",
    "@openai/codex-sdk": "^0.111.0",
    "ai": "^6.0.116",
    "bash-language-server": "^5.6.0",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "slice-ansi": "^8.0.0",
    "string-width": "^8.2.0",
    "strip-ansi": "^7.2.0",
    "typescript-language-server": "^5.1.3",
    "vscode-langservers-extracted": "^4.10.0",
    "wrap-ansi": "^10.0.0",
    "yaml": "^2.7.0",
    "yaml-language-server": "^1.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
